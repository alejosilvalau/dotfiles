font_family      CaskaydiaMono Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto

font_size 12.0

# Add some room to breathe (padding)
window_padding_width 10

background_opacity 0.95
dynamic_background_opacity yes

# Cursor: block, beam, or underline
cursor_shape beam
cursor_blink_interval 0.5

# # --- Colors ---
# foreground            #a9b1d6
# background            #1a1b26
# selection_foreground  #a9b1d6
# selection_background  #7aa2f7
#
# # Cursor colors
# cursor                #c0caf5
# cursor_text_color     #1a1b26
#
# # URL underline color when hovering with mouse
# url_color             #73daca
#
# # The 16 terminal colors
#
# # normal
# color0 #32344a
# color1 #f7768e
# color2 #9ece6a
# color3 #e0af68
# color4 #7aa2f7
# color5 #ad8ee6
# color6 #449dab
# color7 #787c99
#
# # bright
# color8 #444b6a
# color9 #ff7a93
# color10 #b9f27c
# color11 #ff9e64
# color12 #7da6ff
# color13 #bb9af7
# color14 #0db9d7
# color15 #acb0d0

# --- Tab Bar Design ---
hide_window_decorations yes
tab_bar_edge            top
tab_bar_style           powerline
tab_powerline_style     slanted
tab_bar_margin_height   0.0 0.0
tab_bar_min_tabs 1
remember_window_size  no
initial_window_width  640
initial_window_height 400
start_as_fullscreen   yes

# --- Tab Colors (Tokyo Night) ---
# active_tab_foreground   #1a1b26
# active_tab_background   #7aa2f7
# active_tab_font_style   bold
# inactive_tab_foreground #787c99
# inactive_tab_background #16161e
# tab_bar_background      #1a1b26

# --- Tab Title Template ---
# This makes tabs look like:  1: zsh  
tab_title_template "{index}: {title}"

# --- Shortcuts ---
map ctrl+t launch --cwd=current --type=tab

